    label: "\u0420\u0430\u0437\u0440\u044B\u0432 \u043E\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u044F"
    recommendation: "\u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435\u0441\u044C,
      \u0432\u044B\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
      \u043E\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u0435
      \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443."
  - id: oil_spill
    label: "\u0420\u0430\u0437\u043B\u0438\u0432 \u043D\u0435\u0444\u0442\u0438/\u043C\u0430\u0441\u043B\u0430"
    recommendation: "\u041E\u0433\u0440\u0430\u0434\u0438\u0442\u0435 \u043C\u0435\u0441\u0442\u043E,
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435 \u0441\u043E\u0440\u0431\u0435\u043D\u0442
      \u0438 \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u0435 \u043E \u043F\u0440\u043E\u043B\u0438\u0432\u0435."
  - id: hot_pipe
    label: "\u0413\u043E\u0440\u044F\u0447\u0430\u044F \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C
      \u0442\u0440\u0443\u0431\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u0430"
    recommendation: "\u041D\u0435 \u043A\u0430\u0441\u0430\u0439\u0442\u0435\u0441\u044C
      \u0442\u0440\u0443\u0431\u044B \u0431\u0435\u0437 \u0434\u043E\u043F\u0443\u0441\u043A\u0430,
      \u043F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435 \u0442\u0435\u0440\u043C\u043E\u0438\u0437\u043E\u043B\u044F\u0446\u0438\u044E
      \u0438 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u044E\u0449\u0438\u0435
      \u0437\u043D\u0430\u043A\u0438."
  - id: gas_warning
    label: "\u0421\u0438\u0433\u043D\u0430\u043B \u0433\u0430\u0437\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440\u0430"
    recommendation: "\u041F\u043E\u043A\u0438\u043D\u044C\u0442\u0435 \u043E\u043F\u0430\u0441\u043D\u0443\u044E
      \u0437\u043E\u043D\u0443 \u043F\u043E \u0432\u0435\u0442\u0440\u0443, \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u0435
      \u043E\u043F\u043E\u0432\u0435\u0449\u0435\u043D\u0438\u0435 \u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0439\u0442\u0435
      \u043F\u043E \u043F\u043B\u0430\u043D\u0443 \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438."
  - id: unsafe_valve
    label: "\u041E\u0442\u043A\u0440\u044B\u0442\u044B\u0439/\u043D\u0435\u043F\u0440\u043E\u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D"
    recommendation: "\u041D\u0435 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0439\u0442\u0435
      \u0430\u0440\u043C\u0430\u0442\u0443\u0440\u0443 \u0431\u0435\u0437 \u043D\u0430\u0440\u044F\u0434\u0430,
      \u043F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435 \u0431\u0438\u0440\u043A\u0443
      LOTO \u0438 \u0441\u0445\u0435\u043C\u0443 \u0442\u0440\u0443\u0431\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u0430."
